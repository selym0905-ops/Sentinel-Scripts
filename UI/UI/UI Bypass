local Players = game:GetService("Players")
local lp = Players.LocalPlayer

local oldMeta = getrawmetatable(game)
local newMeta = {}
for k, v in pairs(oldMeta) do
    newMeta[k] = v
end

newMeta.__namecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    if method == "LoadAsset" or method == "HttpGet" then
        return nil
    end
    return oldMeta.__namecall(self, ...)
end)

setrawmetatable(game, newMeta)

task.spawn(function()
    while true do
        for _, v in pairs(lp.PlayerGui:GetChildren()) do
            if v.Name:lower():find("dex") or v.Name:lower():find("explorer") then
                v:Destroy()
                print("[Bypass] Dex détecté et supprimé")
            end
        end
        task.wait(3)
    end
end)

print("[Bypass] UI bypass activé")
