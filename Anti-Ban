-- Technique 4: Memory Scan for Ban Flags
local function ScanBanFlags()
    local function scan()
        for _, v in pairs(getgc(true)) do
            if type(v) == "table" then
                if rawget(v, "IsBanned") then
                    rawset(v, "IsBanned", false)
                end
                if rawget(v, "BanStatus") then
                    rawset(v, "BanStatus", "Normal")
                end
                if rawget(v, "CheatDetected") then
                    rawset(v, "CheatDetected", false)
                end
            end
        end
    end
    
    task.spawn(function()
        while true do
            scan()
            task.wait(2)
        end
    end)
end

-- Technique 5: Auto-Rejoin on Kick Attempt
local function AutoRejoin()
    local rejoinAttempts = 0
    local lastKickTime = 0
    
    local oldKickPlayer = nil
    if game.Players.Kick then
        oldKickPlayer = game.Players.Kick
        game.Players.Kick = newcclosure(function(...)
            if tick() - lastKickTime < 5 then
                rejoinAttempts = rejoinAttempts + 1
                if rejoinAttempts >= 3 then
                    print("[Anti-Ban] Multiple kicks detected, rejoining...")
                    game:GetService("TeleportService"):Teleport(game.PlaceId)
                end
            else
                rejoinAttempts = 0
            end
            lastKickTime = tick()
            print("[Anti-Ban] Kick prevented")
            return nil
        end)
    end
end

