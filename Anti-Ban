-- Technique 2: Hook Ban Remotes
local function HookBanRemotes()
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" then
            if rawget(v, "FireServer") then
                local oldFire = v.FireServer
                v.FireServer = newcclosure(function(self, ...)
                    local args = {...}
                    local fullName = tostring(self.Name) .. " " .. tostring(args[1])
                    
                    local banKeywords = {"Ban", "Kick", "Report", "Cheat", "Exploit", "Flag", "Suspect"}
                    for _, keyword in pairs(banKeywords) do
                        if string.find(fullName, keyword) then
                            print("[Anti-Ban] Blocked: " .. keyword)
                            return nil
                        end
                    end
                    
                    return oldFire(self, ...)
                end)
            end
            
            if rawget(v, "InvokeServer") then
                local oldInvoke = v.InvokeServer
                v.InvokeServer = newcclosure(function(self, ...)
                    local args = {...}
                    local fullName = tostring(self.Name) .. " " .. tostring(args[1])
                    
                    local banKeywords = {"Ban", "Kick", "Report", "Cheat", "Exploit", "Flag", "Suspect"}
                    for _, keyword in pairs(banKeywords) do
                        if string.find(fullName, keyword) then
                            print("[Anti-Ban] Blocked invoke: " .. keyword)
                            return nil
                        end
                    end
                    
                    return oldInvoke(self, ...)
                end)
            end
        end
    end
end

