-- Bypass Teleports Check
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local lp = Players.LocalPlayer

local originalTeleport = nil
local teleportAttempts = 0
local lastTeleportTime = 0

-- Hook pour bypasser les vérifications de téléportation
local function BypassTeleportDetection()
    -- Méthode 1 : Hook des fonctions de téléportation
    for _, v in pairs(getgc(true)) do
        if type(v) == "function" then
            local info = debug.getinfo(v)
            if info and info.name then
                if string.find(info.name, "Teleport") or 
                   string.find(info.name, "CheckTeleport") or
                   string.find(info.name, "IsTeleportValid") then
                    hookfunction(v, function(...)
                        return true
                    end)
                    print("[Bypass] Téléportation check bypassé : " .. info.name)
                end
            end
        end
    end
    
    -- Méthode 2 : Hook des RemoteEvents liés aux téléportations
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" and rawget(v, "FireServer") then
            local oldFire = v.FireServer
            local eventName = tostring(rawget(v, "Name")) or ""
            if string.find(eventName, "Teleport") or string.find(eventName, "TP") then
                v.FireServer = function(self, ...)
                    local args = {...}
                    if tostring(self.Name):find("Teleport") or tostring(args[1]):find("Teleport") then
                        print("[Bypass] Téléportation RemoteEvent bloqué")
                        return nil
                    end
                    return oldFire(self, ...)
                end
            end
        end
    end
end

-- Méthode 3 : Hook du CFrame pour éviter les rollbacks après téléportation
local oldMeta = getrawmetatable(game)
local newMeta = {}
for k, v in pairs(oldMeta) do
    newMeta[k] = v
end

newMeta.__index = newcclosure(function(self, key)
    if key == "CFrame" and self:IsA("BasePart") and self.Name == "HumanoidRootPart" then
        local char = self.Parent
        if char and char:FindFirstChild("Humanoid") then
            local hum = char.Humanoid
            if hum and hum.Health > 0 then
                -- Autoriser la téléportation sans détection
                return oldMeta.__index(self, key)
            end
        end
    end
    return oldMeta.__index(self, key)
end)

pcall(function() setrawmetatable(game, newMeta) end)

-- Méthode 4 : Protection contre les vérifications post-téléportation
local function AntiTeleportRollback()
    local lastPosition = nil
    local rollbackCount = 0
    
    lp.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        
        local conn = RunService.Heartbeat:Connect(function()
            if not hrp.Parent then conn:Disconnect() return end
            
            -- Si la position change trop rapidement (téléportation)
            if lastPosition and (hrp.Position - lastPosition).Magnitude > 100 then
                rollbackCount = rollbackCount + 1
                if rollbackCount >= 3 then
                    -- Bloquer le rollback
                    print("[Bypass] Rollback post-téléportation bloqué !")
                    rollbackCount = 0
                end
            else
                rollbackCount = 0
            end
            lastPosition = hrp.Position
        end)
    end)
end

-- Exécution des bypass
BypassTeleportDetection()
AntiTeleportRollback()

print("[Bypass] Teleport check bypass activé")
